---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE, NAV, PLAUSIBLE_DOMAIN } from '../consts';

interface Props {
  title?: string;
  description?: string;
  /** 禁止搜索引擎收录（如 404 页） */
  noindex?: boolean;
  /** OG 图片名（不带扩展名，对应 public/og/<name>.png） */
  ogImage?: string;
  /** 主题：tokyo | nord | snow */
  theme?: 'tokyo' | 'nord' | 'snow';
}

const {
  title,
  description = SITE.description,
  noindex = false,
  ogImage = 'index',
  theme = 'tokyo',
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : SITE.name;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN" data-theme="tokyo">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1A1B26" />
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <!-- 字体：ZCOOL XiaoWei（标题）+ Noto Serif SC（衬线）+ Noto Sans SC（正文·只保留 400/600 共 2 个字重）+ JetBrains Mono（等宽） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=ZCOOL+XiaoWei&family=Noto+Serif+SC:wght@400;600&family=Noto+Sans+SC:wght@400;600&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={`${Astro.site}og/${ogImage}.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${Astro.site}og/${ogImage}.png`} />

    {/* Plausible Analytics（域名通过环境变量配置） */}
    {import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
      <script defer data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
        src="https://plausible.io/js/script.js" />
    )}

    <!-- Anti-FOUC：在 <head> 最早执行，根据 localStorage 立即设置 data-theme -->
    <!-- 默认主题：Tokyo（用户曾在 ThemeSwitcher 切换过则用用户选择） -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('lizigao-box-theme');
          // 无用户偏好时一律使用 Tokyo（不再跟随系统 light/dark）
          if (!t) t = 'tokyo';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'tokyo');
        }
      })();
    </script>
  </head>
  <body class="font-sans">
    <Nav items={NAV} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
