---
import { SITE } from '../consts';
import ThemeSwitcher from './ThemeSwitcher.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  items: readonly NavItem[];
  currentPath: string;
}

const { items, currentPath } = Astro.props;

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  if (href.startsWith('/#')) return false;
  return currentPath.startsWith(href);
};
---

<header class="sticky top-0 z-40 border-b border-border bg-bg-primary/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5 sm:px-8">
    <a href="/" class="group flex items-center gap-2.5">
      <span
        class="grid h-9 w-9 place-items-center rounded-card bg-accent/10 text-text-primary ring-1 ring-border transition-colors group-hover:bg-accent/20"
        aria-hidden="true"
      >
        <span class="font-display text-lg leading-none">栗</span>
      </span>
      <span class="font-display text-xl tracking-wide text-text-primary">
        {SITE.name}
      </span>
    </a>

    <!-- 桌面端：导航 + 主题切换器 -->
    <div class="hidden items-center gap-3 md:flex">
      <nav class="flex items-center gap-1" aria-label="主导航">
        {
          items.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-pill px-4 py-1.5 text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'bg-accent/10 text-text-primary ring-1 ring-border'
                  : 'text-text-secondary hover:bg-bg-secondary hover:text-text-primary',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <ThemeSwitcher />
    </div>

    <!-- 移动端：导航 + 切换器都进 details 菜单 -->
    <details class="relative md:hidden">
      <summary
        class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-pill text-text-secondary ring-1 ring-border transition-colors hover:bg-bg-secondary hover:text-text-primary"
        aria-label="打开菜单"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="18" y2="18" />
        </svg>
      </summary>
      <div
        class="absolute right-0 top-12 z-50 flex w-64 flex-col gap-4 rounded-card border border-border bg-bg-primary/95 p-4 shadow-soft-lg backdrop-blur"
      >
        <nav class="flex flex-col" aria-label="移动端导航">
          {
            items.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'block rounded-md px-3 py-2 text-sm transition-colors',
                  isActive(item.href)
                    ? 'bg-accent/10 text-text-primary'
                    : 'text-text-secondary hover:bg-bg-secondary hover:text-text-primary',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="border-t border-border pt-3">
          <p class="mb-2 font-mono text-[10px] uppercase tracking-widest text-text-tertiary">主题</p>
          <ThemeSwitcher />
        </div>
      </div>
    </details>
  </div>
</header>
