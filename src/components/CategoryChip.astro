---
import { CATEGORY_META, type Category } from '../consts';

interface Props {
  category: Category;
  size?: 'sm' | 'md';
  /** 是否作为按钮样式（带 hover） */
  interactive?: boolean;
}

const { category, size = 'sm', interactive = false } = Astro.props;
const meta = CATEGORY_META[category];

const sizeClass = size === 'md' ? 'text-xs px-3 py-1' : 'text-[11px] px-2.5 py-0.5';
---

<span
  class:list={[
    'inline-flex items-center gap-1.5 rounded-pill border border-border bg-bg-secondary/70 text-text-secondary',
    sizeClass,
    interactive && 'transition-colors hover:border-accent/60 hover:text-text-primary',
  ]}
>
  {meta.label}
</span>
