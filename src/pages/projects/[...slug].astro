---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import CategoryChip from '../../components/CategoryChip.astro';
import Comments from '../../components/Comments.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { data } = project;

const dateStr = data.startDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
});

// 图标
const linkIcons: Record<string, string> = {
  github:   '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  download: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>',
  article:  '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/>',
  external: '<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>',
  demo:     '<path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/>',
};
---

<BaseLayout title={data.title} description={data.summary}>
  <article class="mx-auto max-w-3xl px-5 py-12 sm:px-8 sm:py-16">
    <!-- 返回链接 -->
    <a
      href="/#projects"
      class="group mb-8 inline-flex items-center gap-1.5 text-sm text-text-tertiary transition-colors hover:text-accent"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5">
        <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
      </svg>
      <span>所有项目</span>
    </a>

    <!-- 头部 -->
    <header class="mb-10">
      <div class="mb-4 flex flex-wrap items-center gap-3">
        <StatusBadge status={data.status} size="md" />
        <CategoryChip category={data.category} size="md" />
        <span class="font-mono text-xs text-text-tertiary">起 {dateStr}</span>
      </div>

      <h1 class="font-serif text-3xl font-semibold leading-tight text-text-primary sm:text-4xl text-balance">
        {data.title}
      </h1>
      <p class="mt-4 text-pretty text-lg leading-relaxed text-text-secondary">
        {data.summary}
      </p>

      {
        data.tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-1.5">
            {data.tags.map((tag) => (
              <span class="rounded-md bg-bg-tertiary px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-text-tertiary">
                #{tag}
              </span>
            ))}
          </div>
        )
      }

      {
        data.links.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {data.links.map((link) => (
              <a
                href={link.url}
                target={link.url.startsWith('http') ? '_blank' : undefined}
                rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="group/link inline-flex items-center gap-1.5 rounded-pill border border-border bg-bg-secondary/70 px-3.5 py-1.5 text-sm text-text-secondary transition-all hover:border-accent/60 hover:bg-accent/10 hover:text-text-primary"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <Fragment set:html={linkIcons[link.type] ?? linkIcons.external} />
                </svg>
                <span>{link.label}</span>
                {link.url.startsWith('http') && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 transition-opacity group-hover/link:opacity-80" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <!-- 分割线 -->
    <hr class="mb-10 border-border" />

    <!-- 正文 -->
    <div class="prose-theme max-w-none text-pretty">
      <Content />
    </div>

    <!-- 评论区 -->
    <Comments slug={`projects/${project.id}`} />

    <!-- 底部：其他项目 -->
    <hr class="mt-16 mb-8 border-border" />
    <a
      href="/#projects"
      class="group inline-flex items-center gap-1.5 text-sm text-text-secondary transition-colors hover:text-accent"
    >
      <span>← 返回所有项目</span>
    </a>
  </article>
</BaseLayout>
