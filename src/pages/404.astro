---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="页面不存在" noindex={true}>
  <section class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-5 text-center sm:px-8">
    <p class="mb-4 font-mono text-xs uppercase tracking-[0.3em] text-accent">404</p>
    <h1 class="font-display text-5xl text-text-primary sm:text-7xl">找不到</h1>
    <p class="mt-4 text-text-secondary">
      这页不存在，或者搬走了。
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-1.5 rounded-pill border border-accent/50 bg-accent/15 px-5 py-2 text-sm text-text-primary transition-all hover:bg-accent/25"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
      </svg>
      <span>回首页</span>
    </a>
  </section>
</BaseLayout>
